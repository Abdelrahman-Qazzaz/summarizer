{
  "image": "mcr.microsoft.com/devcontainers/typescript-node",
  "forwardPorts": [3001, 3002, 4000, 5173, 9229, 9230],
  "portsAttributes": {
    "3001": { "label": "API" },
    "3002": { "label": "Transcribe worker" },
    "4000": { "label": "WebSocket" },
    "5173": { "label": "Vite" },
    "9229": { "label": "Node debug (API)" },
    "9230": { "label": "Node debug (transcribe)" }
  },
  "runArgs": [
    "--security-opt=no-new-privileges:true",
    "--cap-drop=ALL",
    "--cap-add=CHOWN",
    "--cap-add=SETUID",
    "--cap-add=SETGID"
  ],
  "containerEnv": {
    "NODE_OPTIONS": "--disable-proto=delete"
  }
}
