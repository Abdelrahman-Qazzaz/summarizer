# Base (API + worker)
# Supabase Postgres connection string (Project Settings → Database → Connection string).
# Prefer a pooler URI — host aws-<n>-<region>.pooler.supabase.com, user
# postgres.<project-ref> — since it resolves over IPv4 and works everywhere:
#   - Session pooler  (port 5432): use for drizzle-kit push / migrations (DDL).
#   - Transaction pooler (port 6543): fine for the app at runtime.
# The direct connection (db.<project-ref>.supabase.co:5432) is IPv6-only and
# will hang in IPv4-only environments (e.g. this devcontainer).
DATABASE_URL=
MQ_URL=
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
OPENROUTER_API_KEY=
NODE_ENV=development

# API only (use localhost everywhere in dev — not 127.0.0.1 — so cookies work with Socket.IO)
SESSION_SECRET=
WORKOS_API_KEY=
WORKOS_CLIENT_ID=
CLIENT_URL=http://localhost:5173
PORT=3001
WS_PORT=4000
UPSTASH_REDIS_REST_URL="https://glad-tapir-146085.upstash.io"
UPSTASH_REDIS_REST_TOKEN="********"

# Worker only
# The worker's /health server binds an OS-assigned ephemeral port (nothing
# dials it), so there's no port to configure here.
# Which consumers this worker attaches: transcribe | summarize | all.
# Deploy the same image as WORKER_ROLE=transcribe and WORKER_ROLE=summarize to
# scale the two pools independently. Defaults to `all` (both in one process).
WORKER_ROLE=all
