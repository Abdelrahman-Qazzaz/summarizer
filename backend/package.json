{
  "name": "summarizer-server",
  "private": true,
  "type": "module",
  "packageManager": "npm@11.14.1",
  "scripts": {
    "dev": "doppler run -- concurrently -k -n api,worker \"tsx watch --inspect=9229 services/api/index.ts\" \"tsx watch --inspect=9230 services/transcribe-summarize-service/index.ts\"",
    "typecheck": "tsc --noEmit",
    "db": "doppler run -- drizzle-kit push",
    "test": "doppler run -- vitest run",
    "test:watch": "doppler run -- vitest"
  },
  "dependencies": {
    "@hono/node-server": "1.19.2",
    "@openrouter/sdk": "^0.12.79",
    "@supabase/supabase-js": "2.103.0",
    "@upstash/redis": "1.38.0",
    "@workos-inc/node": "9.1.0",
    "amqplib": "1.0.3",
    "dotenv": "17.3.1",
    "drizzle-orm": "0.45.2",
    "hono": "4.12.12",
    "hono-rate-limiter": "0.5.3",
    "node-cron": "4.2.1",
    "postgres": "^3.4.9",
    "socket.io": "4.8.3",
    "zod": "3.25.76"
  },
  "devDependencies": {
    "@types/amqplib": "0.10.8",
    "@types/node": "25.6.0",
    "@types/node-cron": "3.0.11",
    "concurrently": "9.2.1",
    "drizzle-kit": "0.31.10",
    "tsx": "4.20.5",
    "typescript": "5.7.3",
    "vitest": "4.1.5"
  }
}
