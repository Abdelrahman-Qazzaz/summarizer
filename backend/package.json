{
  "name": "summarizer-server",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.11",
  "scripts": {
    "dev": "bun run --inspect --watch services/api/index.ts & bun run --inspect --watch services/transcribe-summarize-service/index.ts",
    "mq": "CONF_ENV_FILE=/opt/homebrew/etc/rabbitmq/rabbitmq-env.conf /opt/homebrew/opt/rabbitmq/sbin/rabbitmq-server",
    "typecheck": "tsc --noEmit",
    "db": "drizzle-kit push"
  },
  "dependencies": {
    "@neondatabase/serverless": "1.0.2",
    "@supabase/supabase-js": "2.103.0",
    "amqplib": "1.0.3",
    "dotenv": "17.3.1",
    "drizzle-orm": "0.45.2",
    "hono": "4.12.12",
    "node-cron": "4.2.1",
    "openai": "6.34.0"
  },
  "devDependencies": {
    "@types/amqplib": "0.10.8",
    "@types/bun": "1.2.22",
    "@types/node": "25.6.0",
    "@types/node-cron": "3.0.11",
    "drizzle-kit": "0.31.10",
    "typescript": "5.7.3"
  }
}
